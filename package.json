{
  "name": "discordjs_bun_template",
  "author": "przdev7",
  "module": "main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start:dev": "bun --watch ./src/main.ts",
    "start:prod": "NODE_ENV=production bun dist/main",
    "build": "bun src/build.ts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "format": "prettier --write .",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "deploy:dev": "bun run src/deploy.ts",
    "deploy:prod": "bun run src/deploy.ts --production"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "typescript-eslint": "^8.60.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "joi": "^18.2.1",
    "prettier": "^3.8.3"
  }
}
